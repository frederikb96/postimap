{
  "name": "postimap",
  "version": "0.1.0",
  "description": "Bidirectional IMAP-to-PostgreSQL sync microservice",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/frederikb96/postimap.git"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project pg-integration --project imap-integration",
    "test:integration:pg": "vitest run --project pg-integration",
    "test:integration:imap": "vitest run --project imap-integration",
    "test:e2e": "vitest run --project e2e",
    "test:chaos": "vitest run --project chaos",
    "test:property": "vitest run --project property",
    "test:ci": "vitest run --reporter=junit --outputFile=test-results.xml",
    "test:coverage": "vitest run --coverage",
    "infra:up": "podman compose -f compose.test.yaml up -d",
    "infra:down": "podman compose -f compose.test.yaml down",
    "migrate": "tsx src/db/migrate.ts",
    "infra:reset": "podman compose -f compose.test.yaml down -v && podman compose -f compose.test.yaml up -d",
    "dev:up": "podman compose --env-file .dev.env -f compose.dev.yaml up -d",
    "dev:down": "podman compose -f compose.dev.yaml down",
    "prod:up": "podman compose --env-file .prod.env -f compose.yaml up -d",
    "prod:down": "podman compose -f compose.yaml down"
  },
  "dependencies": {
    "imapflow": "^1.0.0",
    "kysely": "^0.27.0",
    "kysely-postgres-js": "^3.0.0",
    "mailparser": "^3.7.0",
    "nodemailer": "^8.0.0",
    "pg-listen": "^1.7.0",
    "pino": "^9.0.0",
    "postgres": "^3.4.0",
    "yaml": "^2.8.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@faker-js/faker": "^9.0.0",
    "@testcontainers/postgresql": "^10.0.0",
    "@types/mailparser": "^3.4.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.0",
    "fast-check": "^4.0.0",
    "fishery": "^2.2.0",
    "pino-pretty": "^13.0.0",
    "testcontainers": "^10.0.0",
    "toxiproxy-node-client": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
