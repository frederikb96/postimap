# Podman rootless socket
# Ensure Podman socket is enabled: systemctl --user enable --now podman.socket
DOCKER_HOST=unix://${XDG_RUNTIME_DIR}/podman/podman.sock

# Disable Ryuk (privileged cleanup container — fails under rootless Podman)
TESTCONTAINERS_RYUK_DISABLED=true

# Force IPv4 (Podman rootless resolves localhost to IPv6, containers bind IPv4)
NODE_OPTIONS=--dns-result-order=ipv4first
